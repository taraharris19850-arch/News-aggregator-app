<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.heping.newsbroadcast</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/taraharris/Dropbox/Mac/Documents/Claude/Projects/Claduepot Studio folder/新闻播音训练/run_daily.sh</string>
  </array>

  <!-- 每天 09:00 运行 -->
